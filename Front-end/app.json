{
  "expo": {
    "name": "animal-vet",
    "slug": "animal-vet",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "package": "com.arthur.animalvet",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "plugins": [
      [
        "expo-camera",
        {
          "cameraPermission": "Allow Paws & Chat to access your camera to scan pet injuries."
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "560a301e-8ffc-411d-af6c-3c2731a0c458"
      }
    }
  }
}
